# Management — Homarr + Portainer
# Sources: /infrastructure, /stacks/management

{{- $bd := getSecretByName "__INFISICAL_PROJECT_ID__" "__INFISICAL_ENV__" "/infrastructure" "BASE_DOMAIN" }}
{{- $tz := getSecretByName "__INFISICAL_PROJECT_ID__" "__INFISICAL_ENV__" "/infrastructure" "TZ" }}
BASE_DOMAIN={{ $bd.Value }}
TZ={{ $tz.Value }}

{{- $hsk := getSecretByName "__INFISICAL_PROJECT_ID__" "__INFISICAL_ENV__" "/stacks/management" "HOMARR_SECRET_KEY" }}
{{- $pah := getSecretByName "__INFISICAL_PROJECT_ID__" "__INFISICAL_ENV__" "/stacks/management" "PORTAINER_ADMIN_PASSWORD_HASH" }}
HOMARR_SECRET_KEY={{ $hsk.Value }}
PORTAINER_ADMIN_PASSWORD_HASH={{ $pah.Value }}
{{- /* PORTAINER_AUTOMATION_ALLOWED_CIDRS removed: portainer-api Traefik route
   removed; CI automation uses Tailscale IP directly. */ -}}
