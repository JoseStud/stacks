# Alertmanager Configuration
# Rendered by the Infisical Agent and then copied to:
#   /mnt/swarm-shared/observability/alertmanager/alertmanager.yml
# Docs: https://prometheus.io/docs/alerting/latest/configuration/

global:
  resolve_timeout: 5m

route:
  receiver: 'webhook'
  group_by: ['alertname', 'severity']
  group_wait: 30s
  group_interval: 5m
  repeat_interval: 4h
  routes:
    - receiver: 'webhook'
      matchers:
        - severity=~"critical|warning"

receivers:
  - name: 'webhook'
    webhook_configs:
{{- $wh := getSecretByName "__INFISICAL_PROJECT_ID__" "__INFISICAL_ENV__" "/stacks/observability" "ALERTMANAGER_WEBHOOK_URL" }}
{{- if $wh.Value }}
      - url: '{{ $wh.Value }}'
{{- else }}
      - url: 'http://127.0.0.1:65535/'
{{- end }}
        send_resolved: true

inhibit_rules:
  - source_matchers:
      - severity = critical
    target_matchers:
      - severity = warning
    equal: ['alertname', 'instance']
