# Observability — Prometheus + Loki + Grafana
# Sources: /infrastructure, /stacks/observability

{{- $bd := getSecretByName "__INFISICAL_PROJECT_ID__" "__INFISICAL_ENV__" "/infrastructure" "BASE_DOMAIN" }}
{{- $tz := getSecretByName "__INFISICAL_PROJECT_ID__" "__INFISICAL_ENV__" "/infrastructure" "TZ" }}
BASE_DOMAIN={{ $bd.Value }}
TZ={{ $tz.Value }}

{{- $gfci := getSecretByName "__INFISICAL_PROJECT_ID__" "__INFISICAL_ENV__" "/stacks/observability" "GF_OIDC_CLIENT_ID" }}
{{- $gfcs := getSecretByName "__INFISICAL_PROJECT_ID__" "__INFISICAL_ENV__" "/stacks/observability" "GF_OIDC_CLIENT_SECRET" }}
{{- $gfdb := getSecretByName "__INFISICAL_PROJECT_ID__" "__INFISICAL_ENV__" "/stacks/observability" "GF_DB_PASS" }}
{{- $amwh := getSecretByName "__INFISICAL_PROJECT_ID__" "__INFISICAL_ENV__" "/stacks/observability" "ALERTMANAGER_WEBHOOK_URL" }}
GF_OIDC_CLIENT_ID={{ $gfci.Value }}
GF_OIDC_CLIENT_SECRET={{ $gfcs.Value }}
GF_DB_PASS={{ $gfdb.Value }}
ALERTMANAGER_WEBHOOK_URL={{ $amwh.Value }}
