# Network — Vaultwarden + Pi-hole + Orbital Sync
# Sources: /infrastructure, /stacks/network

{{- $bd := getSecretByName "__INFISICAL_PROJECT_ID__" "__INFISICAL_ENV__" "/infrastructure" "BASE_DOMAIN" }}
{{- $tz := getSecretByName "__INFISICAL_PROJECT_ID__" "__INFISICAL_ENV__" "/infrastructure" "TZ" }}
BASE_DOMAIN={{ $bd.Value }}
TZ={{ $tz.Value }}

{{- $vwdb := getSecretByName "__INFISICAL_PROJECT_ID__" "__INFISICAL_ENV__" "/stacks/network" "VW_DB_PASS" }}
{{- $vwat := getSecretByName "__INFISICAL_PROJECT_ID__" "__INFISICAL_ENV__" "/stacks/network" "VW_ADMIN_TOKEN" }}
{{- $php := getSecretByName "__INFISICAL_PROJECT_ID__" "__INFISICAL_ENV__" "/stacks/network" "PIHOLE_PASSWORD" }}
VW_DB_PASS={{ $vwdb.Value }}
VW_ADMIN_TOKEN={{ $vwat.Value }}
PIHOLE_PASSWORD={{ $php.Value }}
PIHOLE_UPSTREAMS=1.1.1.1;8.8.8.8
