# Gateway — Traefik + Socket Proxy
# Sources: /infrastructure, /stacks/gateway

{{- $bd := getSecretByName "__INFISICAL_PROJECT_ID__" "__INFISICAL_ENV__" "/infrastructure" "BASE_DOMAIN" }}
{{- $cf := getSecretByName "__INFISICAL_PROJECT_ID__" "__INFISICAL_ENV__" "/infrastructure" "CLOUDFLARE_API_TOKEN" }}
{{- $zid := getSecretByName "__INFISICAL_PROJECT_ID__" "__INFISICAL_ENV__" "/infrastructure" "ZONE_ID" }}
BASE_DOMAIN={{ $bd.Value }}
CLOUDFLARE_API_TOKEN={{ $cf.Value }}
ZONE_ID={{ $zid.Value }}

{{- $acme := getSecretByName "__INFISICAL_PROJECT_ID__" "__INFISICAL_ENV__" "/stacks/gateway" "ACME_EMAIL" }}
{{- $dsp := getSecretByName "__INFISICAL_PROJECT_ID__" "__INFISICAL_ENV__" "/stacks/gateway" "DOCKER_SOCKET_PROXY_URL" }}
ACME_EMAIL={{ $acme.Value }}
DOCKER_SOCKET_PROXY_URL={{ $dsp.Value }}
