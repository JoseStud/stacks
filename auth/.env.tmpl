# Identity — Authelia SSO
# Sources: /infrastructure, /stacks/identity

{{- with secret "/infrastructure" }}
BASE_DOMAIN={{ .BASE_DOMAIN }}
TZ={{ .TZ }}

# Session cookie domain (derived from BASE_DOMAIN)
AUTH_SESSION_COOKIES_0_DOMAIN={{ .BASE_DOMAIN }}
AUTH_SESSION_COOKIES_0_AUTHELIA_URL=https://auth.{{ .BASE_DOMAIN }}
AUTH_SESSION_COOKIES_0_DEFAULT_REDIRECTION_URL=https://home.{{ .BASE_DOMAIN }}

# TOTP issuer display name
AUTHELIA_TOTP_ISSUER={{ .BASE_DOMAIN }}
{{- end }}

{{- with secret "/stacks/identity" }}
AUTHELIA_JWT_SECRET={{ .AUTHELIA_JWT_SECRET }}
AUTHELIA_SESSION_SECRET={{ .AUTHELIA_SESSION_SECRET }}
POSTGRES_PASSWORD={{ .POSTGRES_PASSWORD }}
AUTHELIA_STORAGE_ENCRYPTION_KEY={{ .AUTHELIA_STORAGE_ENCRYPTION_KEY }}

# SMTP Notifier (Gmail)
AUTHELIA_NOTIFIER_SMTP_USERNAME={{ .AUTHELIA_NOTIFIER_SMTP_USERNAME }}
AUTHELIA_NOTIFIER_SMTP_PASSWORD={{ .AUTHELIA_NOTIFIER_SMTP_PASSWORD }}
AUTHELIA_NOTIFIER_SMTP_SENDER={{ .AUTHELIA_NOTIFIER_SMTP_SENDER }}

# OIDC Provider
AUTHELIA_IDENTITY_PROVIDERS_OIDC_HMAC_SECRET={{ .AUTHELIA_IDENTITY_PROVIDERS_OIDC_HMAC_SECRET }}
AUTH_OIDC_JWKS_0_KEY={{ .AUTHELIA_IDENTITY_PROVIDERS_OIDC_JWKS_0_KEY }}
AUTH_GRAFANA_OIDC_CLIENT_SECRET_HASH={{ .AUTHELIA_IDENTITY_PROVIDERS_OIDC_CLIENTS_0_CLIENT_SECRET }}
{{- end }}
