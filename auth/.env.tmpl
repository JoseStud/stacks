# Identity — Authelia SSO
# Sources: /infrastructure, /stacks/identity

{{- $bd := getSecretByName "__INFISICAL_PROJECT_ID__" "__INFISICAL_ENV__" "/infrastructure" "BASE_DOMAIN" }}
{{- $tz := getSecretByName "__INFISICAL_PROJECT_ID__" "__INFISICAL_ENV__" "/infrastructure" "TZ" }}
BASE_DOMAIN={{ $bd.Value }}
TZ={{ $tz.Value }}

# Session cookie domain (derived from BASE_DOMAIN)
AUTH_SESSION_COOKIES_0_DOMAIN={{ $bd.Value }}
AUTH_SESSION_COOKIES_0_AUTHELIA_URL=https://auth.{{ $bd.Value }}
AUTH_SESSION_COOKIES_0_DEFAULT_REDIRECTION_URL=https://home.{{ $bd.Value }}

# TOTP issuer display name
AUTHELIA_TOTP_ISSUER={{ $bd.Value }}

{{- $jwt := getSecretByName "__INFISICAL_PROJECT_ID__" "__INFISICAL_ENV__" "/stacks/identity" "AUTHELIA_JWT_SECRET" }}
{{- $sess := getSecretByName "__INFISICAL_PROJECT_ID__" "__INFISICAL_ENV__" "/stacks/identity" "AUTHELIA_SESSION_SECRET" }}
{{- $pgpw := getSecretByName "__INFISICAL_PROJECT_ID__" "__INFISICAL_ENV__" "/stacks/identity" "POSTGRES_PASSWORD" }}
{{- $sek := getSecretByName "__INFISICAL_PROJECT_ID__" "__INFISICAL_ENV__" "/stacks/identity" "AUTHELIA_STORAGE_ENCRYPTION_KEY" }}
AUTHELIA_JWT_SECRET={{ $jwt.Value }}
AUTHELIA_SESSION_SECRET={{ $sess.Value }}
POSTGRES_PASSWORD={{ $pgpw.Value }}
AUTHELIA_STORAGE_ENCRYPTION_KEY={{ $sek.Value }}

# SMTP Notifier (Gmail)
{{- $smtpu := getSecretByName "__INFISICAL_PROJECT_ID__" "__INFISICAL_ENV__" "/stacks/identity" "AUTHELIA_NOTIFIER_SMTP_USERNAME" }}
{{- $smtpp := getSecretByName "__INFISICAL_PROJECT_ID__" "__INFISICAL_ENV__" "/stacks/identity" "AUTHELIA_NOTIFIER_SMTP_PASSWORD" }}
{{- $smtps := getSecretByName "__INFISICAL_PROJECT_ID__" "__INFISICAL_ENV__" "/stacks/identity" "AUTHELIA_NOTIFIER_SMTP_SENDER" }}
AUTHELIA_NOTIFIER_SMTP_USERNAME={{ $smtpu.Value }}
AUTHELIA_NOTIFIER_SMTP_PASSWORD={{ $smtpp.Value }}
AUTHELIA_NOTIFIER_SMTP_SENDER={{ $smtps.Value }}

# OIDC Provider
{{- $hmac := getSecretByName "__INFISICAL_PROJECT_ID__" "__INFISICAL_ENV__" "/stacks/identity" "AUTHELIA_IDENTITY_PROVIDERS_OIDC_HMAC_SECRET" }}
{{- $jwks := getSecretByName "__INFISICAL_PROJECT_ID__" "__INFISICAL_ENV__" "/stacks/identity" "AUTHELIA_IDENTITY_PROVIDERS_OIDC_JWKS_0_KEY" }}
{{- $gcsh := getSecretByName "__INFISICAL_PROJECT_ID__" "__INFISICAL_ENV__" "/stacks/identity" "AUTHELIA_IDENTITY_PROVIDERS_OIDC_CLIENTS_0_CLIENT_SECRET" }}
AUTHELIA_IDENTITY_PROVIDERS_OIDC_HMAC_SECRET={{ $hmac.Value }}
AUTH_OIDC_JWKS_0_KEY={{ $jwks.Value }}
AUTH_GRAFANA_OIDC_CLIENT_SECRET_HASH={{ $gcsh.Value }}
